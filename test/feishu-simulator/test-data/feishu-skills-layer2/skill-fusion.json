      "assert": {
        "containsAny": [
          "已创建",
          "创建成功",
          "完成",
          "已为",
          "已在",
          "成功"
        ],
        "matches": "feishu\\.cn",
        "notContains": "error"
      },
      "tags": [
        "P0",
        "fusion",
        "setup"
      ]
    },
    {
      "name": "融合-Setup-创建数据表",
