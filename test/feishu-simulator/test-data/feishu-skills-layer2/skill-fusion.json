{
  "cases": [
    {
      "name": "融合-Setup-创建测试文件夹",
      "message": "帮我在云空间创建一个文件夹叫「融合测试」",
      "assert": {
        "containsAny": [
          "已创建",
          "创建成功",
          "文件夹",
          "完成",
          "已为",
          "成功"
        ],
        "notContains": "error"
      },
      "tags": [
        "P0",
        "fusion",
        "setup"
      ]
    },
    {
      "name": "融合-Setup-创建基础文档",
      "message": "帮我在「融合测试」文件夹下创建一个文档，标题叫《融合-基础文档》，内容写：本周需要完成的事项包括：1. 编写测试用例 2. 修复登录bug 3. 准备季度评审材料 4. 整理API文档",
      "assert": {
        "containsAny": [
          "已创建",
          "创建成功",
          "完成",
          "已为",
          "已在",
          "成功"
        ],
        "matches": "feishu\\.cn",
        "notContains": "error"
      },
      "tags": [
        "P0",
        "fusion",
        "setup"
      ]
    },
    {
      "name": "融合-Setup-创建项目排期文档",
